<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>Trang Chủ - Thư Quán</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <style>
    /* ===== RESET & BASE ===== */
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 15px; color: #2a2620; background: #f6f0e4; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }

    /* ===== PAGE (Block) ===== */
    .page {}

    /* ===== PAGE__HEADER ===== */
    .page__header {
      background: #1b2a20 url('hero-bookstore.jpg') center center / cover no-repeat;
      position: relative;
      padding: 0;
      min-height: 420px;
      display: flex;
      flex-direction: column;
    }

    /* lớp phủ tối lên ảnh nền */
    .page__header::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(15,25,18,0.72) 0%, rgba(15,25,18,0.55) 60%, rgba(15,25,18,0.88) 100%);
    }

    /* ===== HEADER__TOPBAR (logo + tiêu đề) ===== */
    .header__topbar {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 24px 40px 12px;
    }

    .header__image-logo {
      height: 60px;
      width: auto;
      border-radius: 50%;
      border: 2px solid #d9b97a;
      background: rgba(0,0,0,0.3);
    }

    .header__title {
      font-family: Georgia, serif;
      font-size: 28px;
      font-weight: bold;
      color: #fffcf6;
      letter-spacing: 0.03em;
    }

    .header__title em {
      font-style: italic;
      color: #d9b97a;
      font-weight: normal;
    }

    .header__subtitle {
      font-size: 12px;
      color: #dce3d0;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* ===== HEADER__NAV ===== */
    .header__nav {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 4px;
      background: rgba(0,0,0,0.35);
      padding: 10px 40px;
      border-top: 1px solid rgba(255,255,255,0.1);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .nav__link {
      color: #dce3d0;
      font-size: 14px;
      font-weight: 600;
      padding: 7px 14px;
      border-radius: 4px;
      transition: background 0.15s, color 0.15s;
      letter-spacing: 0.02em;
    }

    .nav__link:hover,
    .nav__link--active {
      background: #b8863b;
      color: #fff;
    }

    /* search + cart */
    .nav__search { margin-left: auto; }
    .search__form { display: flex; align-items: center; gap: 8px; }
    .form__input-text {
      padding: 7px 12px;
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 4px 0 0 4px;
      background: rgba(255,255,255,0.12);
      color: #fff;
      font-size: 13.5px;
      width: 200px;
    }
    .form__input-text::placeholder { color: rgba(255,255,255,0.55); }
    .form__input-text:focus { outline: none; background: rgba(255,255,255,0.2); }
    .form__icon-search, .form__icon-cart {
      color: #d9b97a;
      font-size: 16px;
      cursor: pointer;
      padding: 8px 10px;
      background: rgba(255,255,255,0.1);
      border-radius: 0 4px 4px 0;
      transition: background 0.15s;
    }
    .form__icon-search:hover, .form__icon-cart:hover { background: #b8863b; color: #fff; }
    .form__icon-cart { border-radius: 4px; margin-left: 4px; }

    /* ===== HEADER__BANNER (Hero text) ===== */
    .header__banner {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 40px 40px 56px;
      max-width: 640px;
    }

    .banner__eyebrow {
      font-size: 11.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #d9b97a;
      margin-bottom: 14px;
    }

    .banner__title {
      font-family: Georgia, serif;
      font-size: 38px;
      color: #fffcf6;
      line-height: 1.15;
      margin-bottom: 14px;
      font-weight: bold;
    }

    .banner__title em {
      font-style: italic;
      color: #d9b97a;
      font-weight: normal;
    }

    .banner__desc {
      color: #dce3d0;
      font-size: 15px;
      line-height: 1.6;
      margin-bottom: 24px;
      max-width: 480px;
    }

    .banner__cta {
      display: inline-block;
      background: #b8863b;
      color: #1b2a20;
      font-weight: 700;
      font-size: 14.5px;
      padding: 12px 26px;
      border-radius: 5px;
      transition: background 0.15s;
      align-self: flex-start;
    }
    .banner__cta:hover { background: #d9b97a; }

    /* ===== PAGE__MAIN ===== */
    .page__main { padding: 40px; max-width: 1100px; margin: 0 auto; }
    .page__main--one-column { display: block; }

    /* ===== MAIN__ARTICLE ===== */
    .main__article {}

    /* ===== ARTICLE__TITLE ===== */
    .article__title {
      font-family: Georgia, serif;
      font-size: 26px;
      color: #1b2a20;
      margin: 36px 0 18px;
      padding-bottom: 10px;
      border-bottom: 2px solid #b8863b;
    }

    .article__title--primary { font-size: 28px; }

    /* ===== ARTICLE__SECTION ===== */
    .article__section { margin-bottom: 40px; overflow: hidden; }

    /* ===== SECTION__TITLE ===== */
    .section__title {
      font-family: Georgia, serif;
      font-size: 20px;
      color: #3f5a45;
      margin-bottom: 14px;
    }

    .section__title--secondary { border-left: 4px solid #b8863b; padding-left: 12px; }

    /* ===== SECTION__IMAGE ===== */
    .section__image {
      border-radius: 6px;
      margin-bottom: 12px;
    }

    .section__image--float-left {
      float: left;
      margin: 4px 20px 12px 0;
      width: 260px;
    }

    .section__image--float-right {
      float: right;
      margin: 4px 0 12px 20px;
      width: 260px;
    }

    /* ===== SECTION__CONTENT ===== */
    .section__content { line-height: 1.7; color: #2a2620; text-align: justify; }

    /* ===== SECTION__VIDEO ===== */
    .section__video {
      border-radius: 6px;
      width: 320px;
    }

    .section__video--float-right {
      float: right;
      margin: 4px 0 12px 20px;
    }

    /* ===== READ MORE / LESS ===== */
    .content__span--extra-off { display: none; }
    .read-more-less {
      color: #7a2e2e;
      font-weight: 600;
      font-size: 13.5px;
      margin-left: 6px;
      text-decoration: underline;
      cursor: pointer;
    }

    /* ===== THỂ LOẠI (category cards) ===== */
    .section__div-categories {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 16px;
    }

    .category-card {
      border-radius: 7px;
      padding: 22px 18px;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: transform 0.15s;
    }

    .category-card:hover { transform: translateY(-4px); }

    .category-card__code {
      font-family: 'Courier New', monospace;
      font-size: 10.5px;
      opacity: 0.75;
      letter-spacing: 0.05em;
    }

    .category-card__name {
      font-family: Georgia, serif;
      font-size: 18px;
      font-weight: bold;
    }

    .category-card__desc { font-size: 13px; opacity: 0.85; line-height: 1.5; }

    /* ===== QUY TRÌNH ĐẶT HÀNG ===== */
    .section__div-order-steps {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 16px;
    }

    .photo-order-process {
      text-align: center;
      flex: 1;
      min-width: 140px;
      background: #fffcf6;
      border: 1px solid #d8cdb6;
      border-radius: 8px;
      padding: 20px 12px 16px;
    }

    .photo-order-process__image {
      width: 70px;
      height: 70px;
      object-fit: contain;
      margin: 0 auto 12px;
      /* icon thay thế bằng font-awesome */
    }

    .photo-order-process__icon {
      font-size: 42px;
      color: #b8863b;
      margin-bottom: 12px;
    }

    .photo-order-process__caption {
      font-size: 13.5px;
      font-weight: 600;
      color: #1b2a20;
    }

    /* ===== CAM KẾT ===== */
    .section__div-features {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      margin-top: 16px;
    }

    .feature-item {
      border-top: 3px solid #b8863b;
      padding: 16px 10px 10px;
      background: #fffcf6;
      border-radius: 0 0 6px 6px;
    }

    .feature-item__num {
      font-family: 'Courier New', monospace;
      font-size: 11px;
      color: #b8863b;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    .feature-item__title {
      font-family: Georgia, serif;
      font-size: 16px;
      font-weight: bold;
      color: #1b2a20;
      margin-bottom: 6px;
    }

    .feature-item__desc { font-size: 13px; color: #5b5547; line-height: 1.55; }

    /* ===== PAGE__FOOTER ===== */
    .page__footer {
      background: #1b2a20;
      color: #dce3d0;
      text-align: center;
      padding: 22px 40px;
      margin-top: 20px;
    }

    .footer__text { font-size: 13.5px; }

    .footer__link {
      color: #d9b97a;
      margin: 0 6px;
      font-size: 18px;
      transition: color 0.15s;
    }

    .footer__link:hover { color: #fff; }

    .link__image-go-top {
      display: inline;
      width: 20px;
      vertical-align: middle;
    }
  </style>
</head>

<body class="page">

  <!-- ===== PAGE__HEADER ===== -->
  <header class="page__header">

    <!-- Logo + Tên thương hiệu -->
    <div class="header__topbar">
      <i class="fa fa-book" style="font-size:46px; color:#d9b97a;"></i>
      <div>
        <div class="header__title">THƯ <em>QUÁN</em></div>
        <div class="header__subtitle">Hiệu sách trực tuyến</div>
      </div>
    </div>

    <!-- Điều hướng -->
    <nav class="header__nav">
      <a class="nav__link nav__link--active" href="trangchu.html">Trang Chủ</a>
      <a class="nav__link" href="sanpham.html">Sản Phẩm</a>
      <a class="nav__link" href="giohang.html">Giỏ Hàng</a>
      <a class="nav__link" href="dathang.html">Đặt Hàng</a>
      <a class="nav__link" href="dangnhap.html">Đăng Nhập</a>
      <a class="nav__link" href="dangky.html">Đăng Ký</a>
      <a class="nav__link" href="quantri.html">Quản Trị</a>
      <div class="nav__search">
        <form class="search__form" id="formSearch" action="sanpham.html" method="get">
          <input class="form__input-text" type="text" name="inputKeywords" placeholder="Tìm tên sách, tác giả...">
          <i class="fa fa-search form__icon-search"></i>
          <i class="fa fa-shopping-cart form__icon-cart"></i>
        </form>
      </div>
    </nav>

    <!-- Banner / Hero text -->
    <div class="header__banner">
      <div class="banner__eyebrow">&#9135;&#9135; Hiệu sách trực tuyến</div>
      <h1 class="banner__title">Mỗi cuốn sách là<br>một <em>chuyến phiêu lưu</em><br>mới chờ bạn khám phá</h1>
      <p class="banner__desc">Thư Quán tập hợp hơn 8.000 đầu sách được chọn lọc kỹ càng — từ văn học, kinh tế đến sách thiếu nhi, với cam kết 100% sách chính hãng, giao hàng tận nơi.</p>
      <a href="sanpham.html" class="banner__cta">Xem sản phẩm ngay</a>
    </div>

  </header>

  <!-- ===== PAGE__MAIN ===== -->
  <main class="page__main page__main--one-column">
    <article class="main__article">

      <!-- ===== GIỚI THIỆU ===== -->
      <h1 class="article__title article__title--primary">Giới Thiệu Thư Quán</h1>

      <section class="article__section">
        <h2 class="section__title section__title--secondary">Chúng tôi là ai?</h2>
        <img class="section__image section__image--float-left" src="hero-bookstore.jpg" alt="Không gian Thư Quán" style="width:280px;height:190px;object-fit:cover;">
        <p class="section__content">
          Thư Quán là hiệu sách trực tuyến được thành lập với mục tiêu mang những cuốn sách chất lượng đến tay độc giả khắp cả nước một cách nhanh chóng và tiện lợi nhất. Chúng tôi tin rằng sách không chỉ là thứ để đọc — sách là người bạn đồng hành, là cánh cửa mở ra những thế giới mới, những góc nhìn khác biệt và những bài học quý giá trong cuộc sống.
          Xuất phát từ tình yêu sách chân thành, Thư Quán xây dựng hệ thống phân loại rõ ràng giúp bạn dễ dàng tìm đúng cuốn sách phù hợp với sở thích và nhu cầu của mình.
          <span class="content__span content__span--extra-off" id="extraContent1st">
            Mỗi đầu sách trước khi lên kệ đều được đội ngũ biên tập đọc và mô tả lại cẩn thận. Chúng tôi làm việc trực tiếp với các nhà xuất bản lớn như NXB Trẻ, NXB Kim Đồng, NXB Tổng hợp TP.HCM để đảm bảo sách thật, in đẹp, đúng giá và có tem chống giả đầy đủ.
          </span>
          <a href="#!" class="read-more-less" data-target="extraContent1st">Xem thêm</a>
        </p>
      </section>

      <!-- ===== CÁC THỂ LOẠI ===== -->
      <h1 class="article__title article__title--primary">Danh Mục Sách</h1>

      <section class="article__section">
        <h2 class="section__title section__title--secondary">Những kệ sách bạn sẽ tìm thấy</h2>
        <p class="section__content" style="margin-bottom:16px;">
          Tại Thư Quán, sách được phân loại theo hệ thống thể loại rõ ràng, giúp bạn tìm kiếm nhanh và chính xác. Nhấn vào từng thể loại để xem danh sách sản phẩm chi tiết.
          <span class="content__span content__span--extra-off" id="extraContent2nd">
            Ngoài các thể loại chính, Thư Quán còn có khu sách ngoại văn (tiếng Anh, Nhật, Hàn) và sách giáo khoa — học phụ trợ cho học sinh, sinh viên. Cập nhật thường xuyên hàng tuần.
          </span>
          <a href="#!" class="read-more-less" data-target="extraContent2nd">Xem thêm</a>
        </p>

        <div class="section__div-categories">
          <a href="sanpham.html" class="category-card" style="background:linear-gradient(160deg,#7a2e2e,#4f1c1c);">
            <div class="category-card__code">813.6 / VĂN HỌC</div>
            <div class="category-card__name">Văn Học</div>
            <div class="category-card__desc">Tiểu thuyết, truyện ngắn, thơ ca trong và ngoài nước</div>
          </a>
          <a href="sanpham.html" class="category-card" style="background:linear-gradient(160deg,#b8863b,#7c5a24);">
            <div class="category-card__code">658.4 / KINH TẾ</div>
            <div class="category-card__name">Kinh Tế &amp; Quản Trị</div>
            <div class="category-card__desc">Khởi nghiệp, lãnh đạo, tài chính cá nhân</div>
          </a>
          <a href="sanpham.html" class="category-card" style="background:linear-gradient(160deg,#3f5a45,#23332a);">
            <div class="category-card__code">155.4 / THIẾU NHI</div>
            <div class="category-card__name">Thiếu Nhi</div>
            <div class="category-card__desc">Truyện tranh, đồng thoại, sách tư duy cho bé</div>
          </a>
          <a href="sanpham.html" class="category-card" style="background:linear-gradient(160deg,#5b4636,#34281d);">
            <div class="category-card__code">155.2 / KỸ NĂNG</div>
            <div class="category-card__name">Kỹ Năng Sống</div>
            <div class="category-card__desc">Phát triển bản thân, giao tiếp, tư duy tích cực</div>
          </a>
          <a href="sanpham.html" class="category-card" style="background:linear-gradient(160deg,#8c5e3c,#5a3a22);">
            <div class="category-card__code">741.5 / TRUYỆN</div>
            <div class="category-card__name">Truyện Tranh</div>
            <div class="category-card__desc">Manga Nhật, webtoon Hàn, comic trong nước</div>
          </a>
          <a href="sanpham.html" class="category-card" style="background:linear-gradient(160deg,#4a4036,#241f1a);">
            <div class="category-card__code">909 / LỊCH SỬ</div>
            <div class="category-card__name">Lịch Sử</div>
            <div class="category-card__desc">Lịch sử Việt Nam, thế giới, danh nhân, địa lý</div>
          </a>
        </div>
      </section>

      <!-- ===== CAM KẾT ===== -->
      <h1 class="article__title article__title--primary">Tại Sao Chọn Thư Quán</h1>

      <section class="article__section">
        <h2 class="section__title section__title--secondary">Cam kết của chúng tôi với độc giả</h2>
        <div class="section__div-features">
          <div class="feature-item">
            <div class="feature-item__num">01 / GIAO HÀNG</div>
            <div class="feature-item__title">Giao nhanh 2–4 ngày</div>
            <div class="feature-item__desc">Miễn phí vận chuyển cho đơn từ 250.000đ. Đóng gói chống ẩm, chống va đập.</div>
          </div>
          <div class="feature-item">
            <div class="feature-item__num">02 / ĐỔI TRẢ</div>
            <div class="feature-item__title">Đổi trả trong 7 ngày</div>
            <div class="feature-item__desc">Hoàn tiền 100% nếu sách lỗi, in mờ hoặc giao sai đầu sách.</div>
          </div>
          <div class="feature-item">
            <div class="feature-item__num">03 / CHÍNH HÃNG</div>
            <div class="feature-item__title">100% có bản quyền</div>
            <div class="feature-item__desc">Nhập thẳng từ nhà xuất bản, có tem chống giả đầy đủ.</div>
          </div>
          <div class="feature-item">
            <div class="feature-item__num">04 / TÍCH ĐIỂM</div>
            <div class="feature-item__title">Thẻ thành viên</div>
            <div class="feature-item__desc">Tích điểm mỗi lần mua, đổi quà và nhận ưu đãi sinh nhật.</div>
          </div>
        </div>
      </section>

      <!-- ===== QUY TRÌNH ĐẶT HÀNG ===== -->
      <h1 class="article__title article__title--primary">Đặt Hàng Ngay</h1>

      <section class="article__section">
        <h2 class="section__title section__title--secondary">Quy trình mua sách tại Thư Quán</h2>
        <div class="section__div-order-steps">

          <figure class="photo-order-process">
            <div class="photo-order-process__icon"><i class="fa fa-search"></i></div>
            <figcaption class="photo-order-process__caption">Bước 1: Tìm sách</figcaption>
          </figure>

          <figure class="photo-order-process">
            <div class="photo-order-process__icon"><i class="fa fa-shopping-cart"></i></div>
            <figcaption class="photo-order-process__caption">Bước 2: Thêm vào giỏ</figcaption>
          </figure>

          <figure class="photo-order-process">
            <div class="photo-order-process__icon"><i class="fa fa-file-text"></i></div>
            <figcaption class="photo-order-process__caption">Bước 3: Đặt hàng</figcaption>
          </figure>

          <figure class="photo-order-process">
            <div class="photo-order-process__icon"><i class="fa fa-truck"></i></div>
            <figcaption class="photo-order-process__caption">Bước 4: Nhận sách</figcaption>
          </figure>

        </div>
      </section>

    </article>
  </main>

  <!-- ===== PAGE__FOOTER ===== -->
  <footer class="page__footer">
    <p class="footer__text">
      &copy; 2025 Bản quyền thuộc về Thư Quán.
      &nbsp;
      <a href="#!" class="footer__link"><i class="fa fa-facebook-f"></i></a>
      <a href="#!" class="footer__link"><i class="fa fa-twitter"></i></a>
      <a href="#!" class="footer__link"><i class="fa fa-instagram"></i></a>
      &nbsp;&nbsp;
      <a href="#top" class="footer__link" style="font-size:13px;">&#8679; Lên đầu trang</a>
    </p>
  </footer>

  <script>
    // Read more / less — giống form của thầy
    document.querySelectorAll('.read-more-less').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var targetId = this.getAttribute('data-target');
        var span = document.getElementById(targetId);
        if (span.classList.contains('content__span--extra-off')) {
          span.classList.remove('content__span--extra-off');
          this.textContent = 'Ẩn bớt';
        } else {
          span.classList.add('content__span--extra-off');
          this.textContent = 'Xem thêm';
        }
      });
